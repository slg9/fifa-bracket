{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "PUBLIC_SITE_URL": "https://brakup.app"
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/challenge",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/en",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/en/challenge",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "query", "key": "challenge" }],
      "destination": "/challenge",
      "permanent": true
    },
    {
      "source": "/en",
      "has": [{ "type": "query", "key": "challenge" }],
      "destination": "/en/challenge",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/share/bracket/:id", "destination": "/api/bracket-share?id=:id" },
    { "source": "/share/result/:id", "destination": "/api/bracket-share?id=:id" },
    { "source": "/@:pseudo", "destination": "/" },
    { "source": "/admin", "destination": "/" },
    { "source": "/challenge", "destination": "/" },
    { "source": "/challenge/faq", "destination": "/" },
    { "source": "/en", "destination": "/" },
    { "source": "/en/challenge", "destination": "/" },
    { "source": "/en/challenge/faq", "destination": "/" },
    { "source": "/en/(.*)", "destination": "/" }
  ]
}
